{
  "name": "acode-kit-installer",
  "version": "0.1.0",
  "description": "Installer metadata for the Acode-kit multi-agent skill package.",
  "type": "module",
  "scripts": {
    "test:router": "node ./scripts/test-router.mjs",
    "test:entry": "node ./scripts/test-acode-run.mjs",
    "install:win": "powershell -ExecutionPolicy Bypass -File ./scripts/install.ps1"
